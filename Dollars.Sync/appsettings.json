{
    "Serilog": {
        "MinimumLevel": "Verbose",
        "WriteTo": [
            { "Name": "Console" },
            {
                "Name": "File",
                "Args": {
                    "path": "logs/log.txt",
                    "rollingInterval": "Day"
                }
            }
        ]
    },
    "ConnectionStrings": {
        "DefaultConnection": "<user secrets>"
    },
    "SimpleFin": {
        "Enabled": false,
        "AccessUrl": "<user secrets>"
    },
    "Plaid": {
        "Enabled": false,
        "BaseUrl": "https://sandbox.plaid.com",
        "ClientId": "your_client_id_here",
        "Secret": "your_secret_here"
    }
}